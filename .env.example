# ── App ────────────────────────────────────────────────────
APP_NAME=WorkFlow Assistant
APP_ENV=development
API_PORT=8000
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────
POSTGRES_USER=workflow
POSTGRES_PASSWORD=workflow_dev
POSTGRES_DB=workflow_assistant
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://workflow:workflow_dev@postgres:5432/workflow_assistant

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── AI Provider ────────────────────────────────────────────
# OpenAI, Azure OpenAI, o altro provider compatibile
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Sanificazione documenti ─────────────────────────────────
# Domini email aziendali da oscurare (separati da virgola)
SANITIZE_COMPANY_DOMAINS=deloitte.com,deloitte.it
# Parole chiave interne da rimuovere (separate da virgola)
SANITIZE_COMPANY_KEYWORDS=

# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
# SLACK_BOT_TOKEN=
# NOTION_API_KEY=
